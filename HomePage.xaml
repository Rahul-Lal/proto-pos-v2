<Page x:Class="proto_pos_v2.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:proto_pos_v2"
      mc:Ignorable="d" MaxHeight="1080" Height="1080" MaxWidth="1920"
      Title="Burger National" Background="#FF3F7A8E">

    <Grid Name="grdLayout" MaxWidth="1920" Width="1920">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden" Margin="0,0,1475,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                <TextBlock x:Name="txtOutput" TextWrapping="Wrap" FontSize="20" Width="346" MaxHeight="1080" Background="#FFBBBBBB" Foreground="#FF0058CE" Margin="0,0,0,236" TextAlignment="Left" Height="1078" VerticalAlignment="Top" />
                <TextBlock x:Name="txtPrices" TextWrapping="Wrap" FontSize="20" Width="75" MaxHeight="1080" Background="#FFBBBBBB" Foreground="#FF0058CE" TextAlignment="Right" Height="1078" VerticalAlignment="Top" />
            </StackPanel>
        </ScrollViewer>
        <TabControl Margin="421,0,0,167" HorizontalAlignment="Left" Width="1920">
            <TabItem x:Name="btnEuropeanBurger" Header="European Burger" Width="250" Height="100" FontSize="16" HorizontalAlignment="Left" Margin="-1,0,0,0">
                <Grid HorizontalAlignment="Left" Width="1498" Height="818" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300*"/>
                        <ColumnDefinition Width="300*"/>
                        <ColumnDefinition Width="300*"/>
                        <ColumnDefinition Width="300*"/>
                        <ColumnDefinition Width="300*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnSingleOlympian" Content="Single Olympian" Width="266" Height="320" FontSize="16" Margin="10,37,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Click="btnSingleOlympian_Click"/>
                    <Button x:Name="btnDoubleOlympian" Content="Double Olympian" Width="266" Height="320" FontSize="16" Margin="9,37,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Click="btnDoubleOlympian_Click" RenderTransformOrigin="-0.356,0.981" Grid.Column="1"/>
                    <Button x:Name="btnSingleParisian" Content="Single Parisian" Width="266" Height="320" FontSize="16" Margin="10,37,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Click="btnSingleParisian_Click" Grid.Column="2"/>
                    <Button x:Name="btnDoubleParisian" Content="Double Parisian" Width="266" Height="320" FontSize="16" Margin="9,37,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Click="btnDoubleParisian_Click" RenderTransformOrigin="0.5,0.5" Grid.Column="3"/>
                    <Button x:Name="btnSingleRoma" Content="Single Roma" Width="266" Height="320" FontSize="16" Margin="0,37,0,0" HorizontalAlignment="Center" VerticalAlignment="Top" Click="btnSingleRoma_Click" Grid.Column="4"/>
                    <Button x:Name="btnDoubleRoma" Content="Double Roma" Height="320" FontSize="16" Margin="10,38,0,0" VerticalAlignment="Top" Click="btnDoubleRoma_Click" HorizontalAlignment="Left" Width="266" Grid.Row="1" RenderTransformOrigin="0.167,0.55"/>
                    <Button x:Name="btnSingleMatador" Content="Single Matador" Width="266" Height="320" FontSize="16" Margin="9,38,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Click="btnSingleMatador_Click" Grid.Column="1" Grid.Row="1"/>
                    <Button x:Name="btnDoubleMatador" Content="Double Matador" Width="266" Height="320" FontSize="16" Margin="10,38,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Click="btnDoubleMatador_Click" Grid.Column="2" Grid.Row="1"/>
                    <Button x:Name="btnSingleKaiser" Content="Single Kaiser" Width="266" Height="320" FontSize="16" Margin="9,38,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Click="btnSingleKaiser_Click" RenderTransformOrigin="0.582,0.52" Grid.Row="1" Grid.Column="3"/>
                    <Button x:Name="btnDoubleKaiser" Content="Double Kaiser" Width="266" Height="320" FontSize="16" Margin="10,38,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Click="btnDoubleKaiser_Click" Grid.Column="4" Grid.Row="1"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="btnChickenOther" Header="Chicken + Other" Width="250" Height="100" FontSize="16">

            </TabItem>
            <TabItem x:Name="btnSides" Header="Sides" Width="250" Height="100" FontSize="16">

            </TabItem>
            <TabItem x:Name="btnDesserts" Header="Desserts" Width="250" Height="100" FontSize="16" HorizontalAlignment="Center" Margin="0,1,0,-1">

            </TabItem>
            <TabItem x:Name="btnDrinks" Header="Drinks" Width="250" Height="100" FontSize="16">

            </TabItem>
            <TabItem x:Name="btnCombo" Header="Combos + Add-Ons" Width="250" Height="100" FontSize="16">

            </TabItem>
        </TabControl>

        <Label Content="TOTAL: " HorizontalAlignment="Left" Margin="0,844,0,0" VerticalAlignment="Top" Height="69" Width="227" FontSize="36" FontWeight="Bold" Background="#FFBBBBBB" VerticalContentAlignment="Center"/>
        <TextBox x:Name="txtTotal" IsReadOnly="True" HorizontalAlignment="Left" Margin="227,844,0,0" TextWrapping="Wrap" Text="0.00" VerticalAlignment="Top" Width="196" Height="68" FontSize="36" TextAlignment="Center" Background="#FFBBBBBB" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
        <Button x:Name="btnPayment" Click="btnPayment_Click" Content="Pay" HorizontalAlignment="Left" Margin="6,912,0,0" VerticalAlignment="Top" Height="168" Width="417" FontSize="24" />
        <Button x:Name="btnClearOrder" Content="Clear Order" HorizontalAlignment="Left" Margin="421,912,0,0" VerticalAlignment="Top" Height="170" Width="250" Click="btnClearOrder_Click" FontSize="24"/>
        <Button x:Name="btnTenPercentDiscount" Click="btnTenPercentDiscount_Click" Content="10% Discount" HorizontalAlignment="Left" Margin="1165,912,0,0" VerticalAlignment="Top" Height="170" Width="250" FontSize="24" RenderTransformOrigin="0.829,0.476" />
        <Button x:Name="btnStaffMeal" Click="btnStaffMeal_Click" Content="Staff Meal" HorizontalAlignment="Left" Margin="1413,912,0,0" VerticalAlignment="Top" Height="170" Width="250" FontSize="24" />

    </Grid>
</Page>
